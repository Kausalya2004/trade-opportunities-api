# ─────────────────────────────────────────────────────────────
#  .env  –  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# 1. Get a FREE Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Change this to any random long string (keeps tokens secure)
SECRET_KEY=my-super-secret-key-change-this

# 3. How long tokens stay valid (in minutes)
TOKEN_TTL_MINS=60

# 4. Rate limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
